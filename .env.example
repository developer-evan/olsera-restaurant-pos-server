NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/olsera_pos
JWT_SECRET=secure-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: seed the first super admin on startup (only if none exists)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=
SUPER_ADMIN_FIRST_NAME=Super
SUPER_ADMIN_LAST_NAME=Admin
